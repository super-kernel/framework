#!/usr/bin/env php
<?php
declare(strict_types=1);

use SuperKernel\Contract\ApplicationInterface;
use SuperKernel\Framework\ApplicationContext;

include $_composer_autoload_path ?? __DIR__ . '/../vendor/autoload.php';

(function () {
    $container = new SuperKernel\Framework\Provider\ContainerProvider()();

    $application = ApplicationContext::setContainer($container)->get(ApplicationInterface::class);
    $application->run();
})();