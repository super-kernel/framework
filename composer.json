{
    "name": "super-kernel/framework",
    "description": "The framework component for super-kernel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "super-kernel",
        "framework"
    ],
    "homepage": "https://github.com/super-kernel/framework",
    "support": {
        "issues": "https://github.com/super-kernel/framework/issues",
        "source": "https://github.com/super-kernel/framework"
    },
    "autoload": {
        "psr-4": {
            "SuperKernel\\Framework\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperKernelTest\\Framework\\": "tests/"
        }
    },
    "bin": [
        "bin/super-kernel"
    ],
    "config": {
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort‑packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "~8.4.0",
        "super-kernel/attribute": "dev-main",
        "super-kernel/contract": "dev-main"
    },
    "require-dev": {
        "super-kernel/annotator": "dev-main",
        "super-kernel/composer-resolver": "dev-main",
        "super-kernel/di": "dev-main",
        "super-kernel/event-dispatcher": "dev-main",
        "super-kernel/path-resolver": "dev-main",
        "super-kernel/reflector": "dev-main"
    }
}
