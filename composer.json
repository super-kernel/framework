{
    "name": "super-kernel/framework",
    "type": "library",
    "license": "MIT",
    "description": "The framework component for super-kernel.",
    "keywords": [
        "php",
        "super-kernel",
        "framework"
    ],
    "autoload": {
        "psr-4": {
            "SuperKernel\\Framework\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SuperKernelTest\\Framework\\": "tests/src/"
        }
    },
    "config": {
        "sort‑packages": true,
        "optimize-autoloader": true,
        "classmap-authoritative": true
    },
    "minimum-stability": "stable",
    "require": {
        "php": "^8.4",
        "super-kernel/contract": "~1.0",
        "symfony/console": "^7.3",
        "super-kernel/event-dispatcher": "~1.0",
        "super-kernel/annotation": "~1.0"
    },
    "require-dev": {
        "super-kernel/di": "^1.0"
    }
}
